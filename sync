#!/bin/sh
# Burnban paid Sync installer for macOS and Linux.
set -eu
umask 077

VERSION_INPUT="${BURNBAN_SYNC_VERSION:-v0.2.0}"
BASE_URL="${BURNBAN_SYNC_DOWNLOAD_BASE_URL:-}"
TEST_ALLOW_REMOTE_BASE_URL="${BURNBAN_SYNC_TEST_ALLOW_REMOTE_BASE_URL:-false}"
BIN_DIR="${BURNBAN_SYNC_INSTALL_DIR:-$HOME/.local/bin}"
BIN_PATH="$BIN_DIR/burnban-sync"
STATE_PATH="${BURNBAN_SYNC_STATE:-$HOME/.burnban/personal-sync.json}"
SERVER_URL="${BURNBAN_SYNC_URL:-https://sync.burnban.dev}"
NO_START="${BURNBAN_SYNC_NO_START:-0}"
SKIP_ENROLL="${BURNBAN_SYNC_SKIP_ENROLL:-0}"
UNINSTALL=0

usage() {
  cat <<'EOF'
usage: install-sync.sh [--uninstall]

Installs or upgrades burnban-sync and configures a per-user LaunchAgent on
macOS or systemd user service on Linux. Uninstall preserves enrollment state.

Environment:
  BURNBAN_SYNC_VERSION=...            release version (default: v0.2.0)
  BURNBAN_SYNC_DOWNLOAD_BASE_URL=...  authenticated HTTPS URL or local artifact directory
  BURNBAN_SYNC_INSTALL_DIR=...        binary directory (default: ~/.local/bin)
  BURNBAN_SYNC_URL=...                enrollment service URL
  BURNBAN_SYNC_TEST_ALLOW_REMOTE_BASE_URL=true
                                       test-only opt-in for a non-production HTTPS artifact URL
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --uninstall) UNINSTALL=1 ;;
    --help|-h) usage; exit 0 ;;
    *) echo "burnban-sync: unknown installer option: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

case "$TEST_ALLOW_REMOTE_BASE_URL" in
  true|false) ;;
  *)
    echo "burnban-sync: BURNBAN_SYNC_TEST_ALLOW_REMOTE_BASE_URL must be true or false" >&2
    exit 2 ;;
esac

normalize_version() {
  normalized=$1
  case "$normalized" in
    v*) normalized=${normalized#v} ;;
  esac
  printf '%s\n' "$normalized" |
    LC_ALL=C grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?$' || return 1
  printf '%s\n' "$normalized"
}

sync_binary_version() {
  binary_output=$("$1" --version 2>/dev/null) || return 1
  case "$binary_output" in
    'burnban-sync '*) binary_version=${binary_output#burnban-sync } ;;
    *) return 1 ;;
  esac
  normalize_version "$binary_version"
}

is_sync_binary() {
  [ -x "$1" ] && sync_binary_version "$1" >/dev/null
}

is_requested_sync_binary() {
  actual_version=$(sync_binary_version "$1") || return 1
  [ "$actual_version" = "$REQUESTED_VERSION" ]
}

reject_newline() {
  case "$1" in
    *'
'*) echo "burnban-sync: paths containing newlines are not supported" >&2; exit 2 ;;
  esac
}
for value in "$BIN_DIR" "$STATE_PATH" "$BASE_URL"; do reject_newline "$value"; done

OS=$(uname -s | tr '[:upper:]' '[:lower:]')
case "$OS" in
  darwin|linux) ;;
  *) echo "burnban-sync: unsupported operating system: $OS" >&2; exit 1 ;;
esac
ARCH=$(uname -m)
case "$ARCH" in
  x86_64|amd64) ARCH=amd64 ;;
  arm64|aarch64) ARCH=arm64 ;;
  *) echo "burnban-sync: unsupported architecture: $ARCH" >&2; exit 1 ;;
esac

if [ "$OS" = darwin ]; then
  SERVICE_PATH="${BURNBAN_SYNC_SERVICE_PATH:-$HOME/Library/LaunchAgents/dev.burnban.sync.plist}"
else
  SERVICE_PATH="${BURNBAN_SYNC_SERVICE_PATH:-${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/burnban-sync.service}"
fi
reject_newline "$SERVICE_PATH"

managed_service() {
  [ -f "$SERVICE_PATH" ] && grep -Fq 'Burnban installer managed service' "$SERVICE_PATH"
}

stop_service() {
  [ "$NO_START" = 1 ] && return 0
  if [ "$OS" = darwin ]; then
    launchctl bootout "gui/$(id -u)" "$SERVICE_PATH" >/dev/null 2>&1 || true
  elif command -v systemctl >/dev/null 2>&1; then
    systemctl --user disable --now burnban-sync.service >/dev/null 2>&1 || true
  fi
}

if [ "$UNINSTALL" -eq 1 ]; then
  stop_service
  if [ -e "$SERVICE_PATH" ]; then
    if managed_service; then
      rm -f "$SERVICE_PATH"
    else
      echo "burnban-sync: refusing to remove an unrecognized service file: $SERVICE_PATH" >&2
      exit 1
    fi
  fi
  if [ "$NO_START" != 1 ] && [ "$OS" = linux ] && command -v systemctl >/dev/null 2>&1; then
    systemctl --user daemon-reload >/dev/null 2>&1 || true
  fi
  if [ -e "$BIN_PATH" ]; then
    if is_sync_binary "$BIN_PATH"; then
      rm -f "$BIN_PATH"
    else
      echo "burnban-sync: refusing to remove a file that is not burnban-sync: $BIN_PATH" >&2
      exit 1
    fi
  fi
  echo "burnban-sync removed; enrollment state retained at $STATE_PATH"
  exit 0
fi

REQUESTED_VERSION=$(normalize_version "$VERSION_INPUT") || {
  echo "burnban-sync: BURNBAN_SYNC_VERSION must be a release version such as v0.2.0" >&2
  exit 2
}
VERSION="v$REQUESTED_VERSION"

ARCHIVE="burnban-sync_${OS}_${ARCH}.tar.gz"
TMP=$(mktemp -d "${TMPDIR:-/tmp}/burnban-sync-install.XXXXXX")
trap 'rm -rf "$TMP"' EXIT HUP INT TERM

fetch() {
  name=$1
  destination=$2
  if [ -d "$BASE_URL" ]; then
    cp "$BASE_URL/$name" "$destination"
    return
  fi
  case "$BASE_URL" in
    https://*) ;;
    *) echo "burnban-sync: remote downloads must use HTTPS" >&2; exit 1 ;;
  esac
  # Feed the paid credential through curl's standard input. It never appears
  # in a URL, command argument, shell history, or on-disk curl config.
  printf 'header = "Authorization: Bearer %s"\n' "$ACCOUNT_TOKEN" |
    curl --config - --fail --silent --show-error --proto '=https' --tlsv1.2 \
      --max-redirs 0 \
      "$BASE_URL/$name" -o "$destination"
}

ACCOUNT_TOKEN="${BURNBAN_SYNC_ACCOUNT_TOKEN:-}"
PRODUCT="Paid Sync"
if [ ! -d "$BASE_URL" ]; then
  if [ -z "$ACCOUNT_TOKEN" ]; then
    if ! saved_tty=$(stty -g </dev/tty 2>/dev/null); then
      echo "burnban-sync: a terminal is required to authenticate the paid download" >&2
      exit 1
    fi
    printf 'Paste the pst_ Personal or tst_ Team management token (input hidden): ' >/dev/tty
    trap 'stty "$saved_tty" </dev/tty 2>/dev/null || true; rm -rf "$TMP"' EXIT HUP INT TERM
    stty -echo </dev/tty
    IFS= read -r ACCOUNT_TOKEN </dev/tty || {
      stty "$saved_tty" </dev/tty
      printf '\n' >/dev/tty
      echo "burnban-sync: could not read the paid account token" >&2
      exit 1
    }
    stty "$saved_tty" </dev/tty
    printf '\n' >/dev/tty
    trap 'rm -rf "$TMP"' EXIT HUP INT TERM
  fi
  case "$ACCOUNT_TOKEN" in
    pst_*) token_body=${ACCOUNT_TOKEN#pst_}; PRODUCT="Personal Sync"; release_product=personal ;;
    tst_*) token_body=${ACCOUNT_TOKEN#tst_}; PRODUCT="Team Sync"; release_product=team ;;
    *) echo "burnban-sync: a valid pst_ Personal or tst_ Team management token is required" >&2; exit 1 ;;
  esac
  case "$token_body" in
    ''|*[!A-Za-z0-9_-]*)
      echo "burnban-sync: a valid paid management token is required" >&2
      exit 1 ;;
  esac
  if [ "${#token_body}" -lt 16 ]; then
    echo "burnban-sync: a valid paid management token is required" >&2
    exit 1
  fi
  if [ -z "$BASE_URL" ]; then
    BASE_URL="https://sync.burnban.dev/api/v1/$release_product/releases/$VERSION"
  elif [ "$BASE_URL" != "https://sync.burnban.dev/api/v1/$release_product/releases/$VERSION" ] &&
       [ "$TEST_ALLOW_REMOTE_BASE_URL" != true ]; then
    echo "burnban-sync: refusing to send a paid token to a non-production artifact URL; only tests may set BURNBAN_SYNC_TEST_ALLOW_REMOTE_BASE_URL=true" >&2
    exit 1
  fi
fi

echo "Downloading burnban-sync $VERSION for $OS/$ARCH..."
if ! fetch checksums.txt "$TMP/checksums.txt"; then
  echo "burnban-sync: the paid account could not download release $VERSION" >&2
  exit 1
fi
fetch "$ARCHIVE" "$TMP/$ARCHIVE"
expected=$(awk -v file="$ARCHIVE" '$2 == file {print $1; found=1} END {if (!found) exit 1}' "$TMP/checksums.txt") || {
  echo "burnban-sync: $ARCHIVE is missing from checksums.txt" >&2
  exit 1
}
case "$expected" in
  *[!0-9a-fA-F]*|'') echo "burnban-sync: invalid checksum for $ARCHIVE" >&2; exit 1 ;;
esac
if command -v sha256sum >/dev/null 2>&1; then
  actual=$(sha256sum "$TMP/$ARCHIVE" | awk '{print $1}')
else
  actual=$(shasum -a 256 "$TMP/$ARCHIVE" | awk '{print $1}')
fi
if [ "$(printf '%s' "$actual" | tr '[:upper:]' '[:lower:]')" != "$(printf '%s' "$expected" | tr '[:upper:]' '[:lower:]')" ]; then
  echo "burnban-sync: checksum verification failed for $ARCHIVE" >&2
  exit 1
fi

mkdir -p "$TMP/extract" "$BIN_DIR"
tar -xzf "$TMP/$ARCHIVE" -C "$TMP/extract"
candidate="$TMP/extract/burnban-sync"
if [ ! -f "$candidate" ]; then
  echo "burnban-sync: release archive does not contain burnban-sync" >&2
  exit 1
fi
chmod 755 "$candidate"
if ! is_requested_sync_binary "$candidate"; then
  echo "burnban-sync: downloaded executable is not the requested release $VERSION" >&2
  exit 1
fi

if [ -e "$BIN_PATH" ] && ! is_sync_binary "$BIN_PATH"; then
  echo "burnban-sync: refusing to replace a file that is not burnban-sync: $BIN_PATH" >&2
  exit 1
fi
if [ -e "$SERVICE_PATH" ] && ! managed_service; then
  echo "burnban-sync: refusing to replace an unrecognized service file: $SERVICE_PATH" >&2
  exit 1
fi

stop_service
stage="$BIN_DIR/.burnban-sync.$$"
cp "$candidate" "$stage"
chmod 755 "$stage"
mv -f "$stage" "$BIN_PATH"
if ! is_requested_sync_binary "$BIN_PATH"; then
  echo "burnban-sync: installed executable is not the requested release $VERSION" >&2
  exit 1
fi

if [ "$SKIP_ENROLL" != 1 ]; then
  if [ -n "$ACCOUNT_TOKEN" ] || [ ! -f "$STATE_PATH" ]; then
    ledger="${BURNBAN_DB:-$HOME/.burnban/burnban.db}"
    if [ ! -f "$ledger" ]; then
      echo "burnban-sync: initialize the free meter first with: burnban setup --if-needed --no-launch" >&2
      exit 1
    fi
    # The installer is commonly run as `curl ... | sh`, so stdin belongs to the
    # script pipe. Reconnect only the hidden enrollment prompt to the terminal.
    # A supplied token always performs one transient-token sync, including on
    # upgrades, so the newly installed client is verified before supervision.
    if [ -n "$ACCOUNT_TOKEN" ]; then
      BURNBAN_SYNC_ACCOUNT_TOKEN="$ACCOUNT_TOKEN" BURNBAN_SYNC_URL="$SERVER_URL" "$BIN_PATH" --once
    else
      if [ ! -r /dev/tty ]; then
        echo "burnban-sync: enrollment requires an interactive terminal" >&2
        exit 1
      fi
      BURNBAN_SYNC_URL="$SERVER_URL" "$BIN_PATH" --enroll </dev/tty
    fi
  fi
fi

ACCOUNT_TOKEN=
unset ACCOUNT_TOKEN

mkdir -p "$(dirname "$SERVICE_PATH")" "$HOME/.burnban"
if [ "$OS" = darwin ]; then
  xml_path=$(printf '%s' "$BIN_PATH" | sed 's/&/\&amp;/g;s/</\&lt;/g;s/>/\&gt;/g;s/"/\&quot;/g')
  xml_out=$(printf '%s' "$HOME/.burnban/burnban-sync.log" | sed 's/&/\&amp;/g;s/</\&lt;/g;s/>/\&gt;/g;s/"/\&quot;/g')
  cat >"$SERVICE_PATH" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!-- Burnban installer managed service -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
<key>Label</key><string>dev.burnban.sync</string>
<key>ProgramArguments</key><array><string>$xml_path</string></array>
<key>RunAtLoad</key><true/><key>KeepAlive</key><true/>
<key>ThrottleInterval</key><integer>15</integer>
<key>StandardOutPath</key><string>$xml_out</string>
<key>StandardErrorPath</key><string>$xml_out</string>
</dict></plist>
EOF
  chmod 600 "$SERVICE_PATH"
  if [ "$NO_START" != 1 ] && [ -f "$STATE_PATH" ]; then
    launchctl bootstrap "gui/$(id -u)" "$SERVICE_PATH"
  fi
else
  unit_path=$(printf '%s' "$BIN_PATH" | sed 's/\\/\\\\/g;s/"/\\"/g;s/%/%%/g')
  cat >"$SERVICE_PATH" <<EOF
# Burnban installer managed service
[Unit]
Description=Burnban Paid Sync
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart="$unit_path"
Restart=on-failure
RestartSec=15

[Install]
WantedBy=default.target
EOF
  chmod 600 "$SERVICE_PATH"
  if [ "$NO_START" != 1 ] && [ -f "$STATE_PATH" ]; then
    command -v systemctl >/dev/null 2>&1 || {
      echo "burnban-sync: systemd is required for the Linux user service" >&2
      exit 1
    }
    systemctl --user daemon-reload
    systemctl --user enable --now burnban-sync.service
  fi
fi

echo "burnban-sync installed: $BIN_PATH"
if [ -f "$STATE_PATH" ]; then
  echo "$PRODUCT is enrolled and supervised for this user."
else
  echo "Enrollment was skipped; the supervisor will remain stopped until state exists."
fi
