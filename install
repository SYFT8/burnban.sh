#!/bin/sh
# burnban installer — the meter is not live yet.
# Public launch: Tuesday, 14 July 2026, 09:00 ET.
# The real one-liner returns here at launch. Nothing is installed before then,
# and this script phones nobody home — it just prints where to get notified.
set -e
if [ -t 1 ]; then o='\033[38;5;208m'; b='\033[1m'; d='\033[2m'; r='\033[0m'; else o=''; b=''; d=''; r=''; fi
printf '\n'
printf "  ${o}${b}burnban${r} — the meter is not live yet.\n\n"
printf "  Public launch:  ${b}Tuesday, 14 July 2026 · 9:00 AM ET${r}\n"
printf "  ${d}One email the moment the CLI ships (macOS · Linux · Windows):${r}\n\n"
printf "  ${o}→ https://burnban.dev${r}\n\n"
